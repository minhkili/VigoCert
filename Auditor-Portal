// When EU auditor wants to verify a shipment 
async function verifyShipment(trustPassportId: string) {
  // 1. Get record from Vigo Ledger
  const record = await vigoLedger.getRecord(trustPassportId)
  
  // 2. Retrieve original file from Shelby
  const originalPhoto = await shelbyClient.retrieve(record.shelby_cid)
  
  // 3. Verify integrity (SHA-256)
  const currentHash = await computeSHA256(originalPhoto)
  const isIntact = currentHash === record.sha256
  
  return {
    verified: isIntact,
    photo_url: record.shelby_url,
    gps_proof: record.gps,
    blockchain_anchor: record.vigo_mainnet_tx,
  }
}
